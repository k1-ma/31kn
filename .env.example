# ─── Required ─────────────────────────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, RDS, local pg, etc.)
DATABASE_URL=postgres://user:password@host:5432/koshyk

# 32+ char random string used to sign session cookies. **REQUIRED in production.**
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Public origin used in email links. **REQUIRED in production.**
# Must NOT be a Vercel preview URL — those change per deploy.
APP_URL=http://localhost:5173


# ─── Email (Brevo) — optional ─────────────────────────────────────────────────
# Without these, verification + password-reset emails are silently skipped.
# Brevo free tier: 300 emails/day. Create a key under SMTP & API → API Keys.
BREVO_API_KEY=
# Bare address ("noreply@example.com") or named ("Koshyk <noreply@example.com>").
# The sender address/domain must be verified in your Brevo account.
EMAIL_FROM=noreply@example.com

# Require users to confirm their email before they can log in. Off by default.
# Only enforced when email delivery (above) is also configured, otherwise users
# could register but never receive the link. Set to 1/true to turn on.
REQUIRE_EMAIL_VERIFICATION=


# ─── Cookies / multi-domain — optional ────────────────────────────────────────
# When set, sessions are shared across the apex and www subdomains.
# Example: ".koshyk.app"
COOKIE_DOMAIN=

# Comma-separated list of allowed cross-origin Origins in production.
# Same-origin requests are always allowed without listing them here.
CORS_WHITELIST=


# ─── Edge middleware (Vercel) — optional ──────────────────────────────────────
# Single canonical hostname. Requests on any other host are 308-redirected.
CANONICAL_HOST=
# CDN/origin host that should be exempt from the canonical redirect.
ORIGIN_HOST=


# ─── Operations — optional ────────────────────────────────────────────────────
# Run pending migrations automatically on server boot. Off by default.
RUN_MIGRATIONS_ON_BOOT=

# Pool size for pg. Default: 15.
PG_POOL_MAX=

# Disable SSL even for non-localhost connections. Off by default.
PGSSL_DISABLE=

# Body parser limit for /api/state and /api/sync. Default: 100mb.
STATE_BODY_LIMIT=

# Toggles verbose auth + cookie logging.
AUTH_DEBUG=


# ─── Initial admin (seeding only) ─────────────────────────────────────────────
# When set on first boot with RUN_MIGRATIONS_ON_BOOT=1, an admin user is
# created with this username/password. Remove afterwards.
ADMIN_USERNAME=
ADMIN_PASSWORD=
